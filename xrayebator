    echo -e "${CYAN}✓ Отменено${NC}"
    sleep 1
    return
  fi

  # Update selected profile
  if ! safe_jq_write --arg sni "$new_sni" '.sni = $sni' "$PROFILES_DIR/$selected.json"; then
    echo -e "${RED}✗ Ошибка обновления профиля${NC}"
    sleep 2
    return
