  if ! update_transport_settings_for_sni "$port" "$new_sni" "$CONFIG_FILE"; then
    echo -e "${RED}✗ Ошибка обновления config.json${NC}"
    sleep 2
    return
  fi

  safe_restart_xray

  echo ""
  echo -e "${GREEN}✓ SNI профиля '$selected' изменен на: ${YELLOW}$new_sni${NC}"
  echo ""
  echo -e "${MAGENTA}╔═══════════════════════════════════════════════════════════╗${NC}"
