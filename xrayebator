# Безопасная запись через jq — проверяет результат перед перезаписью
# Использование: safe_jq_write "выражение_jq" [аргументы_jq...] "$входной_файл" "$выходной_файл"
# Или для записи в тот же файл: safe_jq_write "выражение_jq" [аргументы_jq...] "$файл"
# Последний аргумент — целевой файл (куда записать), предпоследний — исходный
# Если целевой == исходный, делает mktemp+mv
safe_jq_write() {
  local args=("$@")
  local nargs=${#args[@]}

  # Минимум 2 аргумента: выражение и файл
  if [[ $nargs -lt 2 ]]; then
    echo -e "${RED}  ✗ safe_jq_write: недостаточно аргументов${NC}" >&2
    return 1
  fi

  # Последний аргумент — исходный файл (и он же целевой при in-place)
  local src_file="${args[$((nargs-1))]}"
  local dst_file="$src_file"
  local jq_args=("${args[@]:0:$((nargs-1))}")

  # Сохраняем исходные права и владельца
  local orig_mode orig_owner
  orig_mode=$(stat -c %a "$src_file" 2>/dev/null || echo "644")
  orig_owner=$(stat -c %U:%G "$src_file" 2>/dev/null || echo "root:root")

  local tmp=$(mktemp)
  if jq "${jq_args[@]}" "$src_file" > "$tmp" 2>/dev/null && [[ -s "$tmp" ]]; then
    mv "$tmp" "$dst_file"
    chmod "$orig_mode" "$dst_file" 2>/dev/null
    chown "$orig_owner" "$dst_file" 2>/dev/null
    return 0
  else
    echo -e "${RED}  ✗ Ошибка jq — файл НЕ изменён: $dst_file${NC}" >&2
    rm -f "$tmp"
    return 1
  fi
}

# Создание бэкапа config.json перед миграцией
# Args: $1=migration_name (optional, for logging)
backup_config() {
  local migration_name=${1:-"manual"}
  local backup_dir="/usr/local/etc/xray/backups"
  mkdir -p "$backup_dir"
  chmod 700 "$backup_dir" 2>/dev/null
  chown xray:xray "$backup_dir" 2>/dev/null
  local backup_file="$backup_dir/config_$(date +%Y%m%d_%H%M%S)_${migration_name}.json"
  if ! cp "$CONFIG_FILE" "$backup_file"; then
    echo -e "${RED}  ✗ Не удалось создать бэкап config.json: $backup_file${NC}"
    return 1
  fi
  chmod 600 "$backup_file" 2>/dev/null
  chown xray:xray "$backup_file" 2>/dev/null
  echo -e "${CYAN}  -> Бэкап конфига: $(basename "$backup_file")${NC}"
  return 0
}

# Восстановление прав файлов для пользователя xray
fix_xray_permissions() {
  chown -R xray:xray /usr/local/etc/xray/ 2>/dev/null || true
  chmod 600 /usr/local/etc/xray/.private_key 2>/dev/null || true
}

# Безопасный перезапуск Xray с валидацией конфига
# Returns: 0=success, 1=failure (validation/restart failed; rollback attempted)
safe_restart_xray() {
  if [[ ! -x /usr/local/bin/xray ]]; then
    echo -e "${RED}  ✗ Бинарник /usr/local/bin/xray не найден${NC}"
    return 1
  fi

  if [[ ! -f "$CONFIG_FILE" || ! -s "$CONFIG_FILE" ]]; then
    echo -e "${RED}  ✗ config.json отсутствует или пустой — Xray НЕ перезапущен${NC}"
    local latest_backup
    latest_backup=$(ls -t /usr/local/etc/xray/backups/config_*.json 2>/dev/null | head -1)
    if [[ -n "$latest_backup" ]]; then
      echo -e "${YELLOW}  -> Восстанавливаю конфиг из бэкапа...${NC}"
      cp "$latest_backup" "$CONFIG_FILE"
      echo -e "${GREEN}  ✓ Конфиг восстановлен из: $(basename "$latest_backup")${NC}"
    fi
    return 1
  fi

  local test_output
  test_output=$(/usr/local/bin/xray run -test -config "$CONFIG_FILE" 2>&1)

  if ! grep -qx "Configuration OK." <<< "$test_output"; then
    echo -e "${RED}  ✗ Конфиг не прошёл валидацию -- Xray НЕ перезапущен${NC}"
    echo -e "${YELLOW}  Ошибка: ${test_output}${NC}"

    # Rollback: restore from latest backup if exists
    local latest_backup
    latest_backup=$(ls -t /usr/local/etc/xray/backups/config_*.json 2>/dev/null | head -1)
    if [[ -n "$latest_backup" ]]; then
      echo -e "${YELLOW}  -> Восстанавливаю конфиг из бэкапа...${NC}"
      cp "$latest_backup" "$CONFIG_FILE"
      echo -e "${GREEN}  ✓ Конфиг восстановлен из: $(basename "$latest_backup")${NC}"
    fi
    return 1
  fi

  systemctl restart xray
  sleep 1

  if systemctl is-active --quiet xray; then
    echo -e "${GREEN}  ✓ Xray перезапущен${NC}"
    return 0
  else
    echo -e "${RED}  ✗ Xray не запустился после перезапуска${NC}"
    local latest_backup
    latest_backup=$(ls -t /usr/local/etc/xray/backups/config_*.json 2>/dev/null | head -1)
    if [[ -n "$latest_backup" ]]; then
      echo -e "${YELLOW}  -> Откатываю config.json и пробую вернуть старую конфигурацию...${NC}"
      cp "$latest_backup" "$CONFIG_FILE"
      systemctl restart xray
      sleep 1
      if systemctl is-active --quiet xray; then
        echo -e "${GREEN}  ✓ Xray восстановлен на предыдущем конфиге: $(basename "$latest_backup")${NC}"
      else
        echo -e "${RED}  ✗ Откат конфига не поднял Xray — требуется ручная проверка${NC}"
      fi
    fi
    return 1
  fi
}

# Open port in UFW firewall (idempotent)
# Args: $1=port, $2=protocol (default: tcp)
# Returns: 0=success, 1=failure
open_firewall_port() {
  local port=$1
  local protocol=${2:-tcp}

  # Validate port number
  if [[ ! "$port" =~ ^[0-9]+$ ]] || [[ $port -lt 1 ]] || [[ $port -gt 65535 ]]; then
    echo -e "${RED}  ✗ Неверный порт: $port${NC}" >&2
    return 1
  fi

  # Check if UFW is installed and active
  if ! command -v ufw &>/dev/null; then
    echo -e "${YELLOW}  ⚠ UFW не установлен${NC}" >&2
    return 1
  fi

  if ! ufw status | grep -q "Status: active"; then
    echo -e "${YELLOW}  ⚠ UFW не активен — правило не применено${NC}" >&2
    return 1
  fi

  # Check if port already open (idempotent)
  if ufw status | grep -qE "^${port}/${protocol}.*ALLOW"; then
    echo -e "${CYAN}  → Порт ${port}/${protocol} уже открыт${NC}"
    return 0
  fi

  # Open port
  echo -e "${CYAN}  → Открываю порт ${port}/${protocol}...${NC}"
  if ufw allow "${port}/${protocol}" >/dev/null 2>&1; then
    echo -e "${GREEN}  ✓ Порт ${port}/${protocol} открыт${NC}"
    ufw reload >/dev/null 2>&1
    return 0
  else
    echo -e "${RED}  ✗ Ошибка открытия порта${NC}" >&2
    return 1
  fi
}

# Close port in UFW if not used by other profiles
# Args: $1=port, $2=protocol (default: tcp)
close_firewall_port() {
  local port=$1
  local protocol=${2:-tcp}

  # Check if port is still used by any inbound
  local port_in_use=$(jq -r --argjson port "$port" \
    '.inbounds[] | select(.port == $port) | .tag' \
    "$CONFIG_FILE" 2>/dev/null)

  if [[ -n "$port_in_use" ]]; then
    return 0  # Still in use, don't close
  fi

  # Never close default ports
  local default_ports=(22 80 443 8443 2053 2083 2087 8080 2096 8880 9443)
  for dp in "${default_ports[@]}"; do
    [[ "$port" == "$dp" ]] && return 0
  done

  # Close port
  if ufw status | grep -qE "^${port}/${protocol}.*ALLOW"; then
    echo -e "${CYAN}  → Закрываю порт ${port}/${protocol}...${NC}"
    ufw delete allow "${port}/${protocol}" >/dev/null 2>&1
    ufw reload >/dev/null 2>&1
    echo -e "${GREEN}  ✓ Порт закрыт${NC}"
  fi

  return 0
}

# Get list of profile names using a specific port
# Args: $1=port
# Returns: space-separated profile names
get_profiles_on_port() {
  local port=$1
  local profiles=()

  for pf in "$PROFILES_DIR"/*.json; do
    [[ ! -f "$pf" ]] && continue
    [[ "$pf" == *"_test.json" ]] && continue

    local pp=$(jq -r '.port' "$pf" 2>/dev/null)
    if [[ "$pp" == "$port" ]]; then
      profiles+=("$(basename "$pf" .json)")
    fi
  done

  echo "${profiles[@]}"
}

# Update field for all profiles on a specific port
# Args: $1=port, $2=field, $3=value
update_all_profiles_on_port() {
  local port=$1
  local field=$2
  local value=$3

  local profiles=($(get_profiles_on_port "$port"))

  for pname in "${profiles[@]}"; do
    local pfile="$PROFILES_DIR/$pname.json"
    if safe_jq_write --arg f "$field" --arg v "$value" '.[$f] = $v' "$pfile"; then
      echo -e "${CYAN}  → Обновлен: ${YELLOW}$pname${NC}"
    else
      echo -e "${RED}  ✗ Ошибка обновления: ${YELLOW}$pname${NC}"
    fi
  done
}

# run_migration <marker_basename> <description> <fn_name>
# Centralized migration runner: backup → run fn → safe_restart → touch marker.
# Marker is created ONLY if all phases succeed (idempotency guarantee).
#
# Three-valued return contract for migration fns:
#   fn returns 0 = config changed → safe_restart_xray + touch marker
#   fn returns 1 = no-op (nothing to migrate) → touch marker WITHOUT restart
#   fn returns ≥2 = FAILED → do NOT touch marker (миграция повторится)
#
# Why three-valued: 5 of 6 existing fns return `return 1` для no-op case (нечего
# мигрировать на v2.0+ установке). Binary contract (0=ok, ≥1=fail) приводил бы к
# 5 RED false-positive ошибкам на каждом launch'е v2.0 системы и маркеры никогда
# не выставлялись бы — миграции бесконечно перепроверялись.
#
# Args:
#   marker_basename — file inside /usr/local/etc/xray/, WITHOUT leading dot
#                     (e.g. "xhttp_migrated" → marker /usr/local/etc/xray/.xhttp_migrated)
#   description     — human-readable for logging (Russian, для пользователя)
#   fn_name         — bash function to call. Function MUST:
#                       - return 0 если config changed (рестарт нужен)
#                       - return 1 если no-op (нечего мигрировать, рестарт не нужен)
#                       - return ≥2 если миграция ФАЛЛЕНУЛА (НЕ touch marker)
#                     Function MUST NOT call backup_config or safe_restart_xray itself
#                     (helper делает это централизованно).
#
# Returns: 0=ok (marker set), 1=fn failed (≥2), 2=restart failed
run_migration() {
  local marker_basename="$1"
  local description="$2"
  local fn_name="$3"

  local marker="/usr/local/etc/xray/.${marker_basename}"

  # Skip if already done (idempotent)
  if [[ -f "$marker" ]]; then
    return 0
  fi

  echo -e "${MAGENTA}[migration] ${description}${NC}"

  # Step 1: backup BEFORE any mutation (centralized per REQ-D07).
  # safe_restart_xray's auto-rollback использует latest backup, поэтому
  # backup ДОЛЖЕН быть создан до того, как fn начнёт мутировать config.
  if ! backup_config "$marker_basename"; then
    echo -e "${RED}  ✗ Migration aborted: не удалось создать бэкап${NC}"
    return 1
  fi

  # Step 2: run user-supplied migration fn
  "$fn_name"
  local fn_rc=$?

  case $fn_rc in
    0)
      # Changed config — needs restart
      if safe_restart_xray; then
        touch "$marker"
        chown xray:xray "$marker" 2>/dev/null || true
        echo -e "${GREEN}  ✓ Migration applied: ${marker_basename}${NC}"
        return 0
      else
        echo -e "${RED}  ✗ safe_restart_xray failed для ${description}${NC}"
        echo -e "${YELLOW}    Маркер НЕ выставлен — config откачен (auto-rollback), миграция повторится${NC}"
        return 2
      fi
      ;;
    1)
      # No change — skip restart, but still mark as done (idempotent no-op for next runs).
      # Без этого touch'а fn re-проверял бы (зря) каждый launch.
      touch "$marker"
      chown xray:xray "$marker" 2>/dev/null || true
      echo -e "${CYAN}  ✓ Nothing to migrate: ${marker_basename}${NC}"
      return 0
      ;;
    *)
      # fn вернула ≥2 — реальная ошибка (НЕ no-op).
      echo -e "${RED}  ✗ Migration fn '$fn_name' returned $fn_rc${NC}"
      echo -e "${YELLOW}    Маркер НЕ выставлен — миграция повторится при следующем запуске${NC}"
      return 1
      ;;
  esac
}

migrate_transport_profile_metadata() {
  local migrated=0
  local profile_file

  echo -e "${CYAN}Проверка transport metadata профилей...${NC}"
  # backup_config удалён: централизован в run_migration (Phase 4 refactor, REQ-D07)

  for profile_file in "$PROFILES_DIR"/*.json; do
    [[ ! -f "$profile_file" ]] && continue

    local transport
    transport=$(jq -r '.transport // ""' "$profile_file" 2>/dev/null)

    case "$transport" in
      grpc)
        if [[ "$(jq -r 'has("grpc_service_name")' "$profile_file" 2>/dev/null)" != "true" ]]; then
          echo -e "${YELLOW}  → Backfill grpc_service_name: $(basename "$profile_file" .json)${NC}"
          if safe_jq_write '.grpc_service_name = "grpc"' "$profile_file"; then
            ((migrated++))
          fi
        fi
        ;;
      xhttp)
        if [[ "$(jq -r 'has("xhttp_path")' "$profile_file" 2>/dev/null)" != "true" ]]; then
          echo -e "${YELLOW}  → Backfill xhttp_path: $(basename "$profile_file" .json)${NC}"
          if safe_jq_write '.xhttp_path = "/xhttp"' "$profile_file"; then
            ((migrated++))
          fi
        fi
        ;;
    esac
  done

  fix_xray_permissions

  # EXPLICIT return: 0=changed (restart нужен), 1=no-op (нечего мигрировать)
  # Раньше всегда return 0 — принудительный restart даже когда migrated==0
  if [[ $migrated -gt 0 ]]; then
    echo -e "${GREEN}✓ Transport metadata backfill: $migrated профилей${NC}"
    return 0
  else
    echo -e "${GREEN}✓ Transport metadata backfill не требуется${NC}"
    return 1
  fi
}

# Migration function for existing XHTTP profiles
migrate_xhttp_profiles() {
  local migrated=0

  echo -e "${CYAN}Проверка XHTTP профилей для миграции...${NC}"
  # backup_config удалён: централизован в run_migration (Phase 4 refactor, REQ-D07)

  for profile_file in "$PROFILES_DIR"/*.json; do
    [[ ! -f "$profile_file" ]] && continue

    local transport=$(jq -r '.transport' "$profile_file")
    [[ "$transport" != "xhttp" ]] && continue

    local profile_sni=$(jq -r '.sni' "$profile_file")
    local port=$(jq -r '.port' "$profile_file")

