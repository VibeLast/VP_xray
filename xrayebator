_bypass_apply_bundle() {
  local -a group_ids=()
  local -a group_names=()
  local -a group_domains=()
  local -a state=()
  local gid gname doms_csv

  while IFS='|' read -r gid gname doms_csv; do
    [[ -z "$gid" ]] && continue
    group_ids+=("$gid")
    group_names+=("$gname")
    group_domains+=("$doms_csv")
    state+=("on")
  done < <(_bypass_bundle_groups)

  while true; do
    show_ascii
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo -e "${BLUE}    ДЕФОЛТНЫЙ BYPASS BUNDLE                   ${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${YELLOW}Выберите группы для применения:${NC}"
    echo ""

    local i
    for i in "${!group_ids[@]}"; do
      local mark="[ ]"
      [[ "${state[$i]}" == "on" ]] && mark="[x]"
      local count
      count=$(printf '%s' "${group_domains[$i]}" | tr ',' '\n' | sed '/^$/d' | wc -l)
      echo -e "${CYAN} $((i+1)))${NC} $mark ${group_names[$i]} (${count} доменов)"
    done

    echo ""
    echo -n -e "${YELLOW}Номер группы = toggle, apply = применить, cancel = отмена: ${NC}"
    local choice
    read -r choice
    case "$choice" in
      apply)
        local all_doms_csv=""
        for i in "${!group_ids[@]}"; do
          if [[ "${state[$i]}" == "on" ]]; then
            all_doms_csv="${all_doms_csv}${all_doms_csv:+,}${group_domains[$i]}"
          fi
        done

        if [[ -z "$all_doms_csv" ]]; then
          echo -e "${YELLOW}Нет выбранных групп. Отменено.${NC}"
          sleep 1
          return
        fi

        local doms_json
        doms_json=$(printf '%s' "$all_doms_csv" | tr ',' '\n' | sed '/^$/d' | jq -R '"domain:" + .' | jq -s '.')
        local domain_count
        domain_count=$(printf '%s' "$doms_json" | jq 'length')
        echo -n -e "${YELLOW}Применить ${domain_count} доменов? [y/N]: ${NC}"
        local confirm
        read -r confirm
        [[ "$confirm" =~ ^[yYдД]$ ]] || { echo -e "${CYAN}✓ Отменено${NC}"; sleep 1; return; }

        if _apply_bypass_rule "$doms_json"; then
          echo -e "${GREEN}✓ Дефолтный bundle применен${NC}"
        else
          echo -e "${RED}✗ Bundle не применен${NC}"
        fi
        echo -n -e "${YELLOW}Нажмите Enter для продолжения...${NC}"
        read -r _
        return
        ;;
      cancel|0)
        return
        ;;
      *)
        if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le ${#group_ids[@]} ]]; then
          local idx=$((choice-1))
          if [[ "${state[$idx]}" == "on" ]]; then
            state[$idx]="off"
          else
            state[$idx]="on"
          fi
        else
          echo -e "${RED}Неверный выбор${NC}"
          sleep 1
        fi
        ;;
    esac
  done
}

